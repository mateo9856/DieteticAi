@page "/loadUser"
@using DieteticAI.UI.Services.Login.Abstractions
@using DieteticAI.UI.Services.Login.Requests
@using DieteticAI.UI.Tools
@inject SessionManager SessionManager
@inject IConfiguration Configuration
@inject NavigationManager Navigation
@inject IUserLoginService UserLoginService

<PageTitle>Load User</PageTitle>

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-6">
            <!-- User Info Section -->
            <div class="dietetic-form">
                @if (_isUserTestMode)
                {
                    <div class="alert alert-success" role="alert">
                        <h4 class="alert-heading">✅ User Loaded Successfully!</h4>
                        <p>Your user session has been initialized and is active.</p>
                        <hr>
                        <div class="user-info">
                            <div class="row">
                                <div class="col-md-12 mb-3">
                                    <strong>User ID:</strong>
                                    <div class="user-id-display">
                                        <code>@SessionManager.UserId</code>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-12">
                                    <small class="text-muted">
                                        <i>This unique identifier is stored in your session and will persist throughout your session.</i>
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="login-form">
                        <h3>Login</h3>

                        <EditForm Model="@_loginRequest" OnValidSubmit="Login">
                            <DataAnnotationsValidator />

                            <div class="mb-3">
                                <label for="username" class="form-label">Username</label>
                                <InputText class="form-control" id="username" @bind-Value="_loginRequest.Username" placeholder="Enter username" />
                                <ValidationMessage For="@(() => _loginRequest.Username)" class="text-danger" />
                            </div>

                            <div class="mb-3">
                                <label for="password" class="form-label">Password</label>
                                <InputText type="password" class="form-control" id="password" @bind-Value="_loginRequest.Password" placeholder="Enter password" />
                                <ValidationMessage For="@(() => _loginRequest.Password)" class="text-danger" />
                            </div>

                            <div class="mb-3">
                                <button type="button" class="btn btn-outline-primary w-100 mb-2" @onclick="OidcLogin">
                                    <i class="bi bi-shield-lock"></i> OIDC Connect (Keycloak)
                                </button>
                                <button type="submit" class="btn btn-primary w-100" disabled="@_isLoggingIn">
                                    @if (_isLoggingIn)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                        <span>Logging in...</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-box-arrow-in-right"></i>
                                        <span class="ms-1">Login</span>
                                    }
                                </button>
                            </div>
                        </EditForm>

                        @if (!string.IsNullOrEmpty(ErrorMessage))
                        {
                            <div class="alert alert-danger mt-3" role="alert">
                                @ErrorMessage
                            </div>
                        }
                    </div>
                }
            </div>

            @if (_isUserTestMode)
            {
                <!-- Clear Session Button -->
                <div class="dietetic-form mt-3">
                    <button class="btn btn-danger w-100" @onclick="ClearSession" disabled="@(!SessionManager.IsUserLoaded)">
                        <i class="bi bi-trash"></i> Clear Session
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private readonly LoginRequest _loginRequest = new();
    private bool _isLoggingIn;
    private bool _isUserTestMode;
    private string ErrorMessage { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _isUserTestMode = string.Equals(Configuration["debugUser"], "true", StringComparison.OrdinalIgnoreCase);

        if (TryCompleteKeycloakLogin())
        {
            Navigation.NavigateTo("/loadUser", replace: true);
            return;
        }

        if (!SessionManager.IsUserLoaded && _isUserTestMode)
        {
            await LoginCoreAsync(new LoginRequest
            {
                Username = "admin",
                Password = "password"
            }, true);
        }
    }

    private Task Login() => LoginCoreAsync(new LoginRequest
    {
        Username = _loginRequest.Username,
        Password = _loginRequest.Password
    });

    private async Task LoginCoreAsync(LoginRequest request, bool isTestMode = false)
    {
        if (string.IsNullOrWhiteSpace(request.Username) || string.IsNullOrWhiteSpace(request.Password))
        {
            ErrorMessage = "Please enter both username and password";
            return;
        }

        _isLoggingIn = true;
        ErrorMessage = string.Empty;
        if (isTestMode)
        {
            SessionManager.UserId = Guid.CreateVersion7().ToString();
            return;
        }
        
        try
        {
            await UserLoginService.LoginAsync(request);
            _loginRequest.Password = string.Empty;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            _isLoggingIn = false;
        }
    }

    private Task OidcLogin()
    {
        Navigation.NavigateTo(UserLoginService.GetKeycloakLoginUrl(), forceLoad: true);
        return Task.CompletedTask;
    }

    private bool TryCompleteKeycloakLogin()
    {
        var query = ParseQuery(Navigation.ToAbsoluteUri(Navigation.Uri).Query);

        if (!query.TryGetValue("accessToken", out var accessToken)
            || !query.TryGetValue("userId", out var userId)
            || !query.TryGetValue("expiresAtUtc", out var expiresAtUtc)
            || !DateTime.TryParse(expiresAtUtc, out var expiresAt))
        {
            return false;
        }

        UserLoginService.CompleteLogin(new()
        {
            UserId = userId,
            AccessToken = accessToken,
            ExpiresAtUtc = expiresAt.ToUniversalTime()
        });

        ErrorMessage = string.Empty;
        return true;
    }

    private static Dictionary<string, string> ParseQuery(string query)
    {
        return query.TrimStart('?')
            .Split('&', StringSplitOptions.RemoveEmptyEntries)
            .Select(part => part.Split('=', 2))
            .Where(parts => parts.Length == 2)
            .ToDictionary(
                parts => Uri.UnescapeDataString(parts[0]),
                parts => Uri.UnescapeDataString(parts[1].Replace("+", " ")),
                StringComparer.OrdinalIgnoreCase);
    }

    private void ClearSession()
    {
        UserLoginService.ClearSession();
        _loginRequest.Username = string.Empty;
        _loginRequest.Password = string.Empty;
        ErrorMessage = string.Empty;
        Navigation.NavigateTo("/");
    }
}
