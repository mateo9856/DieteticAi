@page "/loadUser"
@using DieteticAI.UI.Tools
@inject SessionManager SessionManager
@inject NavigationManager Navigation

<PageTitle>Load User</PageTitle>

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-6">
            <!-- Page Header -->
            <div class="page-header">
                <h1>👤 User Session</h1>
                <p>Manage your user session and view your unique identifier</p>
            </div>

            <!-- User Info Section -->
            <div class="dietetic-form">
                @if (SessionManager.IsUserLoaded)
                {
                    <div class="alert alert-success" role="alert">
                        <h4 class="alert-heading">✅ User Loaded Successfully!</h4>
                        <p>Your user session has been initialized and is active.</p>
                        <hr>
                        <div class="user-info">
                            <div class="row">
                                <div class="col-md-12 mb-3">
                                    <strong>User ID:</strong>
                                    <div class="user-id-display">
                                        <code>@SessionManager.UserId</code>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-12">
                                    <small class="text-muted">
                                        <i>This unique identifier is stored in your session and will persist throughout your session.</i>
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="login-form">
                        <h3>Login</h3>
                        <div class="mb-3">
                            <label for="username" class="form-label">Username</label>
                            <input type="text" class="form-control" id="username" @bind="Username" placeholder="Enter username" />
                        </div>
                        <div class="mb-3">
                            <label for="password" class="form-label">Password</label>
                            <input type="password" class="form-control" id="password" @bind="Password" placeholder="Enter password" />
                        </div>
                        <button class="btn btn-primary w-100" @onclick="Login" disabled="@_isLoggingIn">
                            @if (_isLoggingIn)
                            {
                                <span class="spinner-border spinner-border-sm me-2">    Logging in...
                                </span>
                            }
                            else
                            {
                                <i class="bi bi-box-arrow-in-right">Login</i>
                            }
                        </button>
                        @if (!string.IsNullOrEmpty(ErrorMessage))
                        {
                            <div class="alert alert-danger mt-3" role="alert">
                                @ErrorMessage
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Clear Session Button -->
            <div class="dietetic-form mt-3">
                <button class="btn btn-danger w-100" @onclick="ClearSession" disabled="@(!SessionManager.IsUserLoaded)">
                    <i class="bi bi-trash"></i> Clear Session
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private string Username { get; set; } = string.Empty;
    private string Password { get; set; } = string.Empty;
    private bool _isLoggingIn = false;
    private string ErrorMessage { get; set; } = string.Empty;

    protected override void OnInitialized()
    {
        // Load user data if not already loaded
        if (!SessionManager.IsUserLoaded)
        {
            // Generate a unique ID (GUID)
            var uniqueId = Guid.NewGuid().ToString();
            SessionManager.UserId = uniqueId;
        }
    }

    private async Task Login()
    {
        if (string.IsNullOrWhiteSpace(Username) || string.IsNullOrWhiteSpace(Password))
        {
            ErrorMessage = "Please enter both username and password";
            return;
        }

        _isLoggingIn = true;
        ErrorMessage = string.Empty;

        try
        {
            // Simulate authentication (in real app, this would call an API)
            if (Username == "admin" && Password == "password")
            {
                // Generate a unique ID (GUID)
                var uniqueId = Guid.NewGuid().ToString();
                SessionManager.UserId = uniqueId;
            }
            else
            {
                ErrorMessage = "Invalid username or password";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "Login failed: " + ex.Message;
        }
        finally
        {
            _isLoggingIn = false;
        }
    }

    private void ClearSession()
    {
        SessionManager.UserId = null;
        Navigation.NavigateTo("/");
    }
}

